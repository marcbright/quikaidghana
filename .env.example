# -----------------------------------------------------------------------------
# QuickAid Ghana environment template
# -----------------------------------------------------------------------------
# Copy to .env for local/dev use, or configure these directly in Render env vars.

# Core
# Generate a strong key, e.g.:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-strong-random-secret
DJANGO_DEBUG=0

# Render default service domain example (adjust to your actual service name)
DJANGO_ALLOWED_HOSTS=quickaid-ghana.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://quickaid-ghana.onrender.com

# Security (production)
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
DJANGO_CSRF_COOKIE_HTTPONLY=0
DJANGO_LOG_LEVEL=INFO

# PostgreSQL (Render managed database values)
POSTGRES_HOST=replace-with-render-db-host
POSTGRES_PORT=5432
POSTGRES_DB=replace-with-render-db-name
POSTGRES_USER=replace-with-render-db-user
POSTGRES_PASSWORD=replace-with-render-db-password
POSTGRES_SSLMODE=require
POSTGRES_CONN_MAX_AGE=60
