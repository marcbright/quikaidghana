# Core
DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=quickaid.example.com,www.quickaid.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://quickaid.example.com,https://www.quickaid.example.com

# Security (production)
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
DJANGO_CSRF_COOKIE_HTTPONLY=0
DJANGO_LOG_LEVEL=INFO

# PostgreSQL (optional, recommended)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=quickaid
POSTGRES_USER=quickaid
POSTGRES_PASSWORD=change-me
POSTGRES_SSLMODE=require
POSTGRES_CONN_MAX_AGE=60
